exports[`golden snapshots per fixture (F392) > parse: 01-hello.fable 1`] = `
"A fox trotted through the quiet wood.
"
`;

exports[`golden snapshots per fixture (F392) > parse: 02-two-knots.fable 1`] = `
"-> den

=== den ===
The fox curled up in her den.
-> morning

=== morning ===
Sunlight crept across the moss.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 03-choices-basic.fable 1`] = `
"-> crossroads

=== crossroads ===
The path splits beneath an old oak.
* Take the shaded trail.
  Ferns brush your ankles.
  -> crossroads
* Follow the sunny ridge.
  The grass hums with crickets.
  -> crossroads
+ Sit and rest a while.
  -> crossroads
"
`;

exports[`golden snapshots per fixture (F392) > parse: 04-choice-brackets.fable 1`] = `
"-> riverbank

=== riverbank ===
A salmon flashes in the shallows.
* Lunge [at the salmon] at the salmon and miss entirely.
  -> riverbank
+ Wait [patiently] with the patience of winter.
  The salmon drifts closer.
  -> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 05-nested-choices.fable 1`] = `
"-> burrow

=== burrow ===
The rabbit kits crowd around you.
+ Tell them a story.
  * * The one about the moon.
    They gasp at the part with the owl.
  - - They drift to sleep.
  -> END
  * * The one about the river.
    * * * Make the ending happy.
      -> END
    * * * Make the ending true.
      -> END
  + + A story you make up on the spot.
    -> END
+ Shoo them off to bed.
  -> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 06-gathers-labels.fable 1`] = `
"-> clearing

=== clearing ===
Moonlight pools in the clearing.
* (howl) Howl at the moon.
* (dig) Dig at the cold earth.
+ (wait) Do nothing at all.
- (gathered) Whatever you did, the night swallows it.
{howl > 0: Your throat is still sore.}
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 07-variables.fable 1`] = `
"VAR hunger = 3
VAR name = "Reynard"
CONST den_name = "Bramble Hollow"

-> hunt

=== hunt ===
~ temp found = 2
~ hunger = hunger - found
{name} returns to {den_name} with {found} voles.
Hunger is now {hunger}.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 08-expressions.fable 1`] = `
"VAR cunning = 4
VAR boldness = 2
VAR is_winter = false

-> ledger

=== ledger ===
Score: {cunning * 2 + boldness % 3 - 1}.
Verdict: {cunning > 3 && boldness > 1 || is_winter: ready|not ready}.
Plan: {cunning >= boldness ? "scheme" : "charge"}.
Negation: {!is_winter: green season|white season}.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 09-conditionals-inline.fable 1`] = `
"VAR has_key = true
VAR coins = 5

-> gate

=== gate ===
The iron gate is {has_key: unlocked|sealed shut}.
The toll keeper {coins > 3: nods you through|turns you away}.
You feel {has_key: relief}.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 10-alternatives.fable 1`] = `
"-> watch

=== watch ===
The heron {stands|still stands|has not moved}.
The reeds {&whisper|rattle|sigh}.
A frog {~plops|croaks|vanishes}.
+ Keep watching.
  -> watch
+ Leave the marsh.
  -> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 11-glue-tags.fable 1`] = `
"-> intro

=== intro === # chapter: one
The lion yawned. <>
It was a vast yawn. # mood: sleepy
He had eaten well. <> Twice, in fact.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 12-stitches.fable 1`] = `
"-> palace

=== palace ===
The lion's palace is a sun-warmed rock.
-> palace.throne
= throne
He receives visitors here.
-> court
= kitchen
Bones, mostly.
-> END

=== court ===
A jackal pleads his case.
-> palace.kitchen
"
`;

exports[`golden snapshots per fixture (F392) > parse: 13-tunnels.fable 1`] = `
"-> day

=== day ===
The cubs want to play.
-> pounce_lesson ->
After the lesson, everyone naps.
-> END

=== pounce_lesson ===
Crouch. Wiggle. Leap!
->->
"
`;

exports[`golden snapshots per fixture (F392) > parse: 14-lists.fable 1`] = `
"VAR satchel = ["feather", "acorn"]

-> trade

=== trade ===
~ satchel = satchel + "river stone"
{satchel has "acorn": The acorn is safe.|No acorn!}
~ satchel = satchel - "feather"
{satchel hasnt "feather": The feather is gone.}
You carry {COUNT(satchel)} treasures.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 15-comments.fable 1`] = `
"// The fable of the patient stork.
VAR patience = 10 // she has plenty

-> shore

/* The shore is where
   everything happens. */
=== shore ===
The stork waits. // and waits
~ patience = patience - 1 // tick
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 16-bindings.fable 1`] = `
"-> meeting

=== meeting ===
@fox(Reynard the Fox) bows low.
His health sits at @fox.health today.
You recall what the ledger said: [[The Trial of Reynard]].
@crow watches from the elm.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 17-read-counts.fable 1`] = `
"-> spring

=== spring ===
{spring > 1: You have been here before.|The water is new to you.}
+ Drink again.
  -> spring
* Move on.
  -> meadow

=== meadow ===
{spring} visits to the spring brought you here.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 18-fallback-choice.fable 1`] = `
"-> larder

=== larder ===
The larder grows barer each visit.
* Take the last honeycomb.
  -> larder
* Take the dried fish.
  -> larder
* -> empty

=== empty ===
Nothing is left but crumbs and regret.
-> END
"
`;

exports[`golden snapshots per fixture (F392) > parse: 19-escapes.fable 1`] = `
"-> sign

=== sign ===
The sign reads: \\-> market this way \\<>.
A carved \\{rune\\} marks the post. \\# not a tag
The price list: 3 * fish, 2 + eggs.
\\@nobody lives here.
-> END
"
`;

