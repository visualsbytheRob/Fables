exports[`golden disassembly snapshots (F430) > disassembles 04-choice-brackets 1`] = `
"; forge bytecode v1, 526 bytes, checksum 0x7cf6a64f
program v1 entry=#0 containers=6 strings=14 consts=0 temps=0 alts=0

#0 <preamble> (preamble)
    0  DIVERT #1 (riverbank)

#1 riverbank (knot, visits)
    0  VISIT #1 (riverbank)
    1  TEXT "A salmon flashes in the shallows."
    2  NEWLINE
    3  CHOICE 0 - #3 (riverbank#opt1#text) #2 (riverbank#opt1)
    4  CHOICE 1 - #5 (riverbank#opt2#text) #4 (riverbank#opt2)
    5  PRESENT

#2 riverbank#opt1 (choiceBody, visits)
    0  VISIT #2 (riverbank#opt1)
    1  TEXT "Lunge "
    2  TEXT " at the salmon and miss entirely."
    3  NEWLINE
    4  DIVERT #1 (riverbank)

#3 riverbank#opt1#text (choiceText)
    0  TEXT "Lunge "
    1  TEXT "at the salmon"
    2  RET

#4 riverbank#opt2 (choiceBody, visits)
    0  VISIT #4 (riverbank#opt2)
    1  TEXT "Wait "
    2  TEXT " with the patience of winter."
    3  NEWLINE
    4  TEXT "The salmon drifts closer."
    5  NEWLINE
    6  END_STORY

#5 riverbank#opt2#text (choiceText)
    0  TEXT "Wait "
    1  TEXT "patiently"
    2  RET
"
`;

exports[`golden disassembly snapshots (F430) > disassembles 09-conditionals-inline 1`] = `
"; forge bytecode v1, 489 bytes, checksum 0xf77b4d97
program v1 entry=#0 containers=4 strings=15 consts=3 temps=0 alts=0
globals:
  $0 VAR has_key init=#2
  $1 VAR coins init=#3

#0 <preamble> (preamble)
    0  DIVERT #1 (gate)

#1 gate (knot, visits)
    0  VISIT #1 (gate)
    1  TEXT "The iron gate is "
    2  LOAD_GLOBAL $has_key
    3  JUMP_IF_FALSE @6
    4  TEXT " unlocked"
    5  JUMP @7
    6  TEXT "sealed shut"
    7  TEXT "."
    8  NEWLINE
    9  TEXT "The toll keeper "
   10  LOAD_GLOBAL $coins
   11  PUSH_CONST 3
   12  GT
   13  JUMP_IF_FALSE @16
   14  TEXT " nods you through"
   15  JUMP @17
   16  TEXT "turns you away"
   17  TEXT "."
   18  NEWLINE
   19  TEXT "You feel "
   20  LOAD_GLOBAL $has_key
   21  JUMP_IF_FALSE @23
   22  TEXT " relief"
   23  TEXT "."
   24  NEWLINE
   25  END_STORY

#2 has_key#init (init)
    0  PUSH_CONST true
    1  RET

#3 coins#init (init)
    0  PUSH_CONST 5
    1  RET
"
`;

exports[`golden disassembly snapshots (F430) > disassembles 17-read-counts 1`] = `
"; forge bytecode v1, 526 bytes, checksum 0x3c82eb0e
program v1 entry=#0 containers=7 strings=12 consts=1 temps=0 alts=0

#0 <preamble> (preamble)
    0  DIVERT #1 (spring)

#1 spring (knot, visits)
    0  VISIT #1 (spring)
    1  LOAD_VISITS #1 (spring)
    2  PUSH_CONST 1
    3  GT
    4  JUMP_IF_FALSE @7
    5  TEXT " You have been here before."
    6  JUMP @8
    7  TEXT "The water is new to you."
    8  NEWLINE
    9  CHOICE 1 - #4 (spring#opt1#text) #3 (spring#opt1)
   10  CHOICE 0 - #6 (spring#opt2#text) #5 (spring#opt2)
   11  PRESENT

#2 meadow (knot, visits)
    0  VISIT #2 (meadow)
    1  LOAD_VISITS #1 (spring)
    2  PRINT
    3  TEXT " visits to the spring brought you here."
    4  NEWLINE
    5  END_STORY

#3 spring#opt1 (choiceBody, visits)
    0  VISIT #3 (spring#opt1)
    1  TEXT "Drink again."
    2  NEWLINE
    3  DIVERT #1 (spring)

#4 spring#opt1#text (choiceText)
    0  TEXT "Drink again."
    1  RET

#5 spring#opt2 (choiceBody, visits)
    0  VISIT #5 (spring#opt2)
    1  TEXT "Move on."
    2  NEWLINE
    3  DIVERT #2 (meadow)

#6 spring#opt2#text (choiceText)
    0  TEXT "Move on."
    1  RET
"
`;

exports[`golden disassembly snapshots (F430) > disassembles 22-builtins 1`] = `
"; forge bytecode v1, 492 bytes, checksum 0x726d5731
program v1 entry=#0 containers=3 strings=10 consts=4 temps=2 alts=0
globals:
  $0 VAR den_count init=#2

#0 <preamble> (preamble)
    0  DIVERT #1 (divvy)

#1 divvy (knot, visits)
    0  VISIT #1 (divvy)
    1  PUSH_CONST 1
    2  PUSH_CONST 6
    3  CALL_BUILTIN RANDOM 2
    4  STORE_TEMP t0
    5  LOAD_TEMP t0
    6  LOAD_GLOBAL $den_count
    7  DIV
    8  CALL_BUILTIN FLOOR 1
    9  STORE_TEMP t1
   10  TEXT "Each den gets "
   11  LOAD_TEMP t1
   12  PUSH_CONST 1
   13  CALL_BUILTIN MAX 2
   14  PRINT
   15  TEXT " hare"
   16  LOAD_TEMP t1
   17  PUSH_CONST 1
   18  SUB
   19  CALL_BUILTIN ABS 1
   20  PUSH_CONST 0
   21  NEQ
   22  JUMP_IF_FALSE @24
   23  TEXT " s"
   24  TEXT "."
   25  NEWLINE
   26  TEXT "After "
   27  TURNS
   28  PRINT
   29  TEXT " turns, the hunt ends."
   30  NEWLINE
   31  END_STORY

#2 den_count#init (init)
    0  PUSH_CONST 3
    1  RET
"
`;
