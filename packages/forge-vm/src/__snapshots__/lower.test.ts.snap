exports[`lowering snapshots (F410) > dumps the multi-file include fixture 1`] = `
"program v1 entry=#0 containers=9 strings=16 consts=2 temps=0 alts=0
meta: title="The Wandering Fox"
globals:
  $0 VAR spirit init=#4

#0 <preamble> (preamble)
    0  DIVERT #1 (forest_edge)

#1 forest_edge (knot, visits)
    0  VISIT #1 (forest_edge)
    1  TEXT "Pines crowd the path."
    2  NEWLINE
    3  LOAD_GLOBAL $spirit
    4  PUSH_CONST 1
    5  ADD
    6  STORE_GLOBAL $spirit
    7  CHOICE 0 - #6 (forest_edge#opt1#text) #5 (forest_edge#opt1)
    8  CHOICE 1 - #8 (forest_edge#opt2#text) #7 (forest_edge#opt2)
    9  PRESENT

#2 forest_heart (knot, visits)
    0  VISIT #2 (forest_heart)
    1  TEXT "It is dark and very quiet."
    2  NEWLINE
    3  DIVERT #3 (river_bend)

#3 river_bend (knot, visits)
    0  VISIT #3 (river_bend)
    1  TEXT "The river runs quick and cold. Spirit: "
    2  LOAD_GLOBAL $spirit
    3  PRINT
    4  TEXT "."
    5  NEWLINE
    6  END_STORY

#4 spirit#init (init)
    0  PUSH_CONST 2
    1  RET

#5 forest_edge#opt1 (choiceBody, visits)
    0  VISIT #5 (forest_edge#opt1)
    1  TEXT "Head deeper in."
    2  NEWLINE
    3  DIVERT #2 (forest_heart)

#6 forest_edge#opt1#text (choiceText)
    0  TEXT "Head deeper in."
    1  RET

#7 forest_edge#opt2 (choiceBody, visits)
    0  VISIT #7 (forest_edge#opt2)
    1  TEXT "Follow the water sounds."
    2  NEWLINE
    3  DIVERT #3 (river_bend)

#8 forest_edge#opt2#text (choiceText)
    0  TEXT "Follow the water sounds."
    1  RET
"
`;
