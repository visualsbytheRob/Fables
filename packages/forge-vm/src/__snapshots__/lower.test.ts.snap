    3  TEXT "stands"
    4  JUMP @9
    5  TEXT "still stands"
    6  JUMP @9
    7  TEXT "has not moved"
    8  JUMP @9
    9  TEXT "."
   10  NEWLINE
   11  TEXT "The reeds "
   12  ALT 1 1 [@13, @15, @17]
   13  TEXT "whisper"
   14  JUMP @19
   15  TEXT "rattle"
   16  JUMP @19
   17  TEXT "sigh"
   18  JUMP @19
   19  TEXT "."
   20  NEWLINE
   21  TEXT "A frog "
   22  ALT 2 2 [@23, @25, @27]
   23  TEXT "plops"
   24  JUMP @29
   25  TEXT "croaks"
   26  JUMP @29
   27  TEXT "vanishes"
   28  JUMP @29
   29  TEXT "."
   30  NEWLINE
   31  CHOICE 1 - #3 (watch#opt1#text) #2 (watch#opt1)
   32  CHOICE 1 - #5 (watch#opt2#text) #4 (watch#opt2)
   33  PRESENT

#2 watch#opt1 (choiceBody, visits)
    0  VISIT #2 (watch#opt1)
    1  TEXT "Keep watching."
    2  NEWLINE
    3  DIVERT #1 (watch)

#3 watch#opt1#text (choiceText)
    0  TEXT "Keep watching."
    1  RET

#4 watch#opt2 (choiceBody, visits)
    0  VISIT #4 (watch#opt2)
    1  TEXT "Leave the marsh."
    2  NEWLINE
    3  END_STORY

#5 watch#opt2#text (choiceText)
    0  TEXT "Leave the marsh."
    1  RET
"
`;

