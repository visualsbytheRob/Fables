"
`;

exports[`lowering snapshots (F410) > dumps stable IR for 06-gathers-labels 1`] = `
"program v1 entry=#0 containers=9 strings=15 consts=1 temps=0 alts=0

#0 <preamble> (preamble)
    0  DIVERT #1 (clearing)

#1 clearing (knot, visits)
    0  VISIT #1 (clearing)
    1  TEXT "Moonlight pools in the clearing."
    2  NEWLINE
    3  CHOICE 0 - #6 (clearing.howl#text) #2 (clearing.howl)
    4  CHOICE 0 - #7 (clearing.dig#text) #3 (clearing.dig)
    5  CHOICE 1 - #8 (clearing.wait#text) #4 (clearing.wait)
    6  PRESENT

#2 clearing.howl (choiceBody, visits)
    0  VISIT #2 (clearing.howl)
    1  TEXT "Howl at the moon."
    2  NEWLINE
    3  DIVERT #5 (clearing.gathered)

#3 clearing.dig (choiceBody, visits)
    0  VISIT #3 (clearing.dig)
    1  TEXT "Dig at the cold earth."
    2  NEWLINE
    3  DIVERT #5 (clearing.gathered)

#4 clearing.wait (choiceBody, visits)
    0  VISIT #4 (clearing.wait)
    1  TEXT "Do nothing at all."
    2  NEWLINE
    3  DIVERT #5 (clearing.gathered)

#5 clearing.gathered (gather, visits)
    0  VISIT #5 (clearing.gathered)
    1  TEXT "Whatever you did, the night swallows it."
    2  NEWLINE
    3  LOAD_VISITS #2 (clearing.howl)
    4  PUSH_CONST 0
    5  GT
    6  JUMP_IF_FALSE @8
    7  TEXT " Your throat is still sore."
    8  NEWLINE
    9  END_STORY

#6 clearing.howl#text (choiceText)
    0  TEXT "Howl at the moon."
    1  RET

#7 clearing.dig#text (choiceText)
    0  TEXT "Dig at the cold earth."
    1  RET

#8 clearing.wait#text (choiceText)
    0  TEXT "Do nothing at all."
    1  RET
"
`;

exports[`lowering snapshots (F410) > dumps stable IR for 10-alternatives 1`] = `
"program v1 entry=#0 containers=6 strings=21 consts=0 temps=0 alts=3

#0 <preamble> (preamble)
    0  DIVERT #1 (watch)

#1 watch (knot, visits)
    0  VISIT #1 (watch)
    1  TEXT "The heron "
