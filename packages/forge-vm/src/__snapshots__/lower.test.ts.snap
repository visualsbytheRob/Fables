    1  TEXT "Follow the sunny ridge."
    2  NEWLINE
    3  TEXT "The grass hums with crickets."
    4  NEWLINE
    5  DIVERT #1 (crossroads)

#5 crossroads#opt2#text (choiceText)
    0  TEXT "Follow the sunny ridge."
    1  RET

#6 crossroads#opt3 (choiceBody, visits)
