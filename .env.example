# Fables server configuration (all optional — sensible defaults apply)
# Precedence: CLI flags > environment > fables.config.json > defaults

# PORT=4870
# HOST=127.0.0.1
# DATA_DIR=~/.fables
# LOG_LEVEL=info            # fatal|error|warn|info|debug|trace
# NODE_ENV=development      # development|test|production

# Policy: no secrets live in this repo. Anything sensitive belongs in your
# local .env (gitignored) or your shell profile.
