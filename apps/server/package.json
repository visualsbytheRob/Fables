{
  "name": "@fables/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "db:backup": "tsx src/db/cli.ts backup",
    "db:check": "tsx src/db/cli.ts check",
    "db:seed": "tsx src/db/cli.ts seed",
    "import:vault": "tsx src/cli/import.ts",
    "import": "tsx src/cli/import-source.ts"
  },
  "dependencies": {
    "@fables/core": "workspace:*",
    "@fables/forge-dsl": "workspace:*",
    "@fables/forge-vm": "workspace:*",
    "@fables/plugin-sdk": "workspace:*",
    "@fables/sync": "workspace:*",
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/etag": "^6.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.2.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.0.0",
    "fflate": "^0.8.3",
    "linkedom": "^0.18.12",
    "pdfjs-dist": "^6.0.227",
    "pino-roll": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.21",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.0"
  }
}
